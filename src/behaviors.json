            "integrationId": "{{integrationId}}",
            "integrationKey": "{{integrationKey}}",
            "configId": "{{configId}}",
            "behaviorDeviceKey": "weatherxm_station",
            "optionKey": "state_changed",
            "capability": "telemetry.state"
          }
        },
        "intent": "monitor_weather",
        "conditionTree": {
          "id": "wind_gust_above_template",
          "label": "Wind gust is above 16 m/s",
          "field": "wind_gust_ms",
          "operator": ">",
          "value": 16,
          "sourceRef": {
            "integrationId": "{{integrationId}}",
            "integrationKey": "{{integrationKey}}",
            "configId": "{{configId}}",
            "behaviorDeviceKey": "weatherxm_station",
            "optionKey": "wind_gust_above",
            "capability": "sensor.wind_gust_ms"
          }
        },
        "conditions": {
          "integrationCondition": {
            "id": "wind_gust_above",
            "params": {
              "meters_per_second": 16
            }
          }
        },
        "actions": [
          {
            "id": "refresh",
            "label": "Refresh this station",
            "action": "command",
            "capability": "action.refresh",
            "sourceRef": {
              "integrationId": "{{integrationId}}",
              "integrationKey": "{{integrationKey}}",
              "configId": "{{configId}}",
              "behaviorDeviceKey": "weatherxm_station",
              "optionKey": "refresh",
              "capability": "action.refresh"
            },
            "target": {
              "mode": "selection",
              "configIds": ["{{configId}}"]
            },
            "parameters": {},
            "failure": {
              "strategy": "retry_then_continue",
              "retry": {
                "maxAttempts": 2,
                "delaySeconds": 5,
                "timeoutSeconds": 5,
                "backoff": "fixed"
              },
              "continueOnPartialFailure": true
            }
          }
        ],
        "safety": {
          "staleDataMode": "warn",
          "maxAgeSeconds": 600,
          "requireFreshTrigger": false,
          "dryRunFirst": false
        },
        "failure": {
