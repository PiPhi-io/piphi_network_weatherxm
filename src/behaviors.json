  "templates": [
    {
      "id": "weatherxm_wind_gust_refresh",
      "label": "Refresh WeatherXM when wind picks up",
      "description": "When a saved WeatherXM station reports strong wind gusts, refresh that station so PiPhi has the latest weather reading.",
      "category": "Weather",
      "deviceKey": "weatherxm_station",
      "config": {
        "automation_schema_version": "automation.behavior.v2",
        "triggers": [
          {
            "id": "state_changed",
            "label": "WeatherXM reading changes",
            "type": "integration_event",
            "event": "device.state_changed",
